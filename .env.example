# Aplicacoes
NODE_ENV=development
WEB_PORT=3000
API_PORT=3333
APP_URL=http://localhost:3000
API_URL=http://localhost:3333
NEXT_PUBLIC_API_URL=http://localhost:3333

# Banco de dados
POSTGRES_PORT=5432
POSTGRES_DB=senha_do_vaqueiro
POSTGRES_USER=senha_do_vaqueiro
POSTGRES_PASSWORD=senha_do_vaqueiro
DATABASE_URL=postgresql://senha_do_vaqueiro:senha_do_vaqueiro@localhost:5432/senha_do_vaqueiro?schema=public

# Redis / filas
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Autenticacao
JWT_ACCESS_SECRET=troque-este-segredo-de-acesso
JWT_REFRESH_SECRET=troque-este-segredo-de-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Pagamentos Pix
PIX_PROVIDER=mock
PIX_WEBHOOK_SECRET=troque-este-segredo-do-webhook

# Arquivos e imagens
STORAGE_PROVIDER=local
STORAGE_BUCKET=senha-do-vaqueiro-dev
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=local-access-key
STORAGE_SECRET_KEY=local-secret-key
