# Aplicacao
NODE_ENV=production
APP_URL=https://senhadovaqueiro.com
API_URL=https://api.senhadovaqueiro.com
NEXT_PUBLIC_API_URL=https://api.senhadovaqueiro.com

# Portas internas dos containers. Nao publicar no host da VPS.
WEB_PORT=3100
API_PORT=3400

# Banco gerenciado externo. Use SSL se o provedor exigir.
DATABASE_URL=postgresql://usuario:senha@host-gerenciado:5432/senha_do_vaqueiro?schema=public&sslmode=require

# Redis interno do compose de producao.
REDIS_PORT=6381
REDIS_URL=redis://redis:6381
ENABLE_PAYMENT_EXPIRATION_WORKER=true

# Autenticacao
JWT_ACCESS_SECRET=troque-por-um-segredo-forte-com-32-caracteres-ou-mais
JWT_REFRESH_SECRET=troque-por-outro-segredo-forte-com-32-caracteres-ou-mais
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_DOMAIN=.senhadovaqueiro.com
COOKIE_SECURE=true

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=cole-aqui-o-token-do-tunnel

# Pagamentos Pix
PIX_PROVIDER=mock
PIX_WEBHOOK_SECRET=troque-por-um-segredo-forte-do-webhook
PIX_CLIENT_ID=
PIX_CLIENT_SECRET=
PIX_CERT_PATH=

# Arquivos e imagens
STORAGE_PROVIDER=s3
STORAGE_BUCKET=
STORAGE_REGION=auto
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Backup logico opcional feito pela VPS
BACKUP_DIR=/opt/backups/senha-do-vaqueiro
BACKUP_RETENTION_DAYS=7
