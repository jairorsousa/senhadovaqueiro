generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SYSTEM_ADMIN
  ORGANIZER
  COWBOY
}

enum EventStatus {
  DRAFT
  ACTIVE
  CLOSED
  CANCELLED
}

enum CategoryStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum TicketStatus {
  AVAILABLE
  RESERVED
  PENDING_PAYMENT
  PAID
  CANCELLED
  BLOCKED
}

enum OrderStatus {
  DRAFT
  WAITING_PAYMENT
  PAID
  EXPIRED
  CANCELLED
  PAYMENT_FAILED
}

enum PaymentStatus {
  WAITING_PAYMENT
  PAID
  EXPIRED
  CANCELLED
  FAILED
}

model User {
  id           String      @id @default(uuid()) @db.Uuid
  name         String
  email        String      @unique
  passwordHash String      @map("password_hash")
  role         UserRole
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  eventUsers   EventUser[]
  auditLogs    AuditLog[]

  @@index([role])
  @@index([isActive])
  @@map("users")
}

model Cowboy {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  cpf          String   @unique
  whatsapp     String
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  orders       Order[]

  @@index([name])
  @@index([whatsapp])
  @@index([isActive])
  @@map("cowboys")
}

model Event {
  id          String      @id @default(uuid()) @db.Uuid
  name        String
  slug        String      @unique
  city        String
  state       String
  location    String
  description String?
  rules       String?
  bannerUrl   String?     @map("banner_url")
  startsAt    DateTime    @map("starts_at")
  endsAt      DateTime    @map("ends_at")
  status      EventStatus @default(DRAFT)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  eventUsers  EventUser[]
  categories  Category[]
  eventDays   EventDay[]
  ticketMaps  TicketMap[]
  orders      Order[]

  @@index([status, startsAt])
  @@index([city, state])
  @@map("events")
}

model EventUser {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      UserRole @default(ORGANIZER)
  createdAt DateTime @default(now()) @map("created_at")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
  @@index([eventId])
  @@map("event_users")
}

model Category {
  id          String         @id @default(uuid()) @db.Uuid
  eventId     String         @map("event_id") @db.Uuid
  name        String
  description String?
  ticketPrice Decimal        @map("ticket_price") @db.Decimal(12, 2)
  prizeAmount Decimal?       @map("prize_amount") @db.Decimal(12, 2)
  cattleCount Int?           @map("cattle_count")
  usesDays    Boolean        @default(false) @map("uses_days")
  status      CategoryStatus @default(DRAFT)
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  event       Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  days        CategoryDay[]
  ticketMaps  TicketMap[]

  @@unique([eventId, name])
  @@index([eventId, status])
  @@index([status])
  @@map("categories")
}

model EventDay {
  id         String        @id @default(uuid()) @db.Uuid
  eventId    String        @map("event_id") @db.Uuid
  name       String
  startsAt   DateTime      @map("starts_at")
  endsAt     DateTime?     @map("ends_at")
  sortOrder  Int           @default(0) @map("sort_order")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  event      Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  categories CategoryDay[]
  ticketMaps TicketMap[]

  @@unique([eventId, startsAt])
  @@index([eventId, startsAt])
  @@map("event_days")
}

model CategoryDay {
  id         String   @id @default(uuid()) @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  eventDayId String   @map("event_day_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  eventDay   EventDay @relation(fields: [eventDayId], references: [id], onDelete: Cascade)

  @@unique([categoryId, eventDayId])
  @@index([eventDayId])
  @@map("category_days")
}

model TicketMap {
  id            String         @id @default(uuid()) @db.Uuid
  eventId       String         @map("event_id") @db.Uuid
  categoryId    String         @map("category_id") @db.Uuid
  eventDayId    String?        @map("event_day_id") @db.Uuid
  name          String
  firstNumber   Int            @default(1) @map("first_number")
  lastNumber    Int            @map("last_number")
  status        CategoryStatus @default(ACTIVE)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category      Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  eventDay      EventDay?      @relation(fields: [eventDayId], references: [id], onDelete: SetNull)
  ticketNumbers TicketNumber[]

  @@index([eventId])
  @@index([categoryId, eventDayId])
  @@index([status])
  @@map("ticket_maps")
}

model TicketNumber {
  id                 String       @id @default(uuid()) @db.Uuid
  ticketMapId        String       @map("ticket_map_id") @db.Uuid
  number             Int
  status             TicketStatus @default(AVAILABLE)
  reservedUntil      DateTime?    @map("reserved_until")
  currentOrderItemId String?      @unique @map("current_order_item_id") @db.Uuid
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  ticketMap          TicketMap    @relation(fields: [ticketMapId], references: [id], onDelete: Cascade)
  currentOrderItem   OrderItem?   @relation("CurrentTicketOrderItem", fields: [currentOrderItemId], references: [id], onDelete: SetNull)
  orderItems         OrderItem[]  @relation("TicketNumberOrderItems")

  @@unique([ticketMapId, number])
  @@index([ticketMapId, status])
  @@index([status])
  @@map("ticket_numbers")
}

model Order {
  id          String      @id @default(uuid()) @db.Uuid
  cowboyId    String?     @map("cowboy_id") @db.Uuid
  eventId     String      @map("event_id") @db.Uuid
  status      OrderStatus @default(DRAFT)
  totalAmount Decimal     @map("total_amount") @db.Decimal(12, 2)
  expiresAt   DateTime?   @map("expires_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  cowboy      Cowboy?     @relation(fields: [cowboyId], references: [id], onDelete: Restrict)
  event       Event       @relation(fields: [eventId], references: [id], onDelete: Restrict)
  items       OrderItem[]
  payments    Payment[]

  @@index([eventId, status])
  @@index([cowboyId, status])
  @@index([status, expiresAt])
  @@map("orders")
}

model OrderItem {
  id             String        @id @default(uuid()) @db.Uuid
  orderId        String        @map("order_id") @db.Uuid
  ticketNumberId String        @map("ticket_number_id") @db.Uuid
  unitPrice      Decimal       @map("unit_price") @db.Decimal(12, 2)
  createdAt      DateTime      @default(now()) @map("created_at")
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketNumber   TicketNumber  @relation("TicketNumberOrderItems", fields: [ticketNumberId], references: [id], onDelete: Restrict)
  currentTicket  TicketNumber? @relation("CurrentTicketOrderItem")

  @@unique([orderId, ticketNumberId])
  @@index([ticketNumberId])
  @@map("order_items")
}

model Payment {
  id                String         @id @default(uuid()) @db.Uuid
  orderId           String         @map("order_id") @db.Uuid
  provider          String
  providerPaymentId String         @map("provider_payment_id")
  status            PaymentStatus  @default(WAITING_PAYMENT)
  amount            Decimal        @db.Decimal(12, 2)
  pixQrCode         String?        @map("pix_qr_code")
  pixCopyPaste      String?        @map("pix_copy_paste")
  expiresAt         DateTime?      @map("expires_at")
  paidAt            DateTime?      @map("paid_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  order             Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events            PaymentEvent[]

  @@unique([provider, providerPaymentId])
  @@index([orderId, status])
  @@index([status, expiresAt])
  @@map("payments")
}

model PaymentEvent {
  id              String    @id @default(uuid()) @db.Uuid
  paymentId       String?   @map("payment_id") @db.Uuid
  provider        String
  externalEventId String    @map("external_event_id")
  eventType       String    @map("event_type")
  payload         Json
  receivedAt      DateTime  @default(now()) @map("received_at")
  processedAt     DateTime? @map("processed_at")
  payment         Payment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([provider, externalEventId])
  @@index([paymentId])
  @@index([receivedAt])
  @@map("payment_events")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id") @db.Uuid
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
  @@map("audit_logs")
}
